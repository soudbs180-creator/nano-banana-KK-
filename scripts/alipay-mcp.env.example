# Alipay MCP local config template
# Copy to scripts/alipay-mcp.env and fill values.

AP_APP_ID=your_app_id
AP_APP_KEY=your_app_private_key
AP_APP_PUBLIC_KEY=your_app_public_key
AP_PUB_KEY=your_alipay_public_key
AP_RETURN_URL=https://your-domain.com/pay/success
AP_NOTIFY_URL=https://your-domain.com/api/alipay/notify
AP_ENCRYPTION_ALGO=RSA2
AP_CURRENT_ENV=sandbox
AP_SELECT_TOOLS=create-alipay-payment-agent,query-alipay-payment
AP_LOG_ENABLED=true
