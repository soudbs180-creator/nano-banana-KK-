# ==============================
# KK-Studio 节点支付服务器配置库
# ==============================

PORT=8080

# 1. 前端域名（支付成功后回跳页面）
FRONTEND_URL=http://localhost:5173/

# 2. 回调网关域名 (支付宝必须能够访问这个地址进行异步通知)
# 如果本地测试，请使用 ngrok 或 natapp 等内网穿透工具，或保持空让本地失效
PAYMENT_NOTIFY_URL=http://your-domain.com/api/pay/notify/alipay

# 3. 支付宝核心凭证
ALIPAY_APP_ID=202100xxxxxxx你的APPID
ALIPAY_PRIVATE_KEY=MIIE... 你的应用私钥
ALIPAY_PUBLIC_KEY=MIIB... 你的截图上的“支付宝公钥”
ALIPAY_ENCRYPT_KEY=4vaXut... 你的截图上的 AES 加密串

# 4. Supabase 对接（核心安全秘钥）
# 这就是前面你获取到的，只有这个秘钥能调用扣除费用的 RPC
SUPABASE_SECRET_KEY=sb_secret_u-W5wWOP0oH2JyMJ5L7OHg_Zcxt3fek

# 5. [敬请期待] WeChat Pay 凭证
WECHATPAY_APPID=
WECHATPAY_MCHID=
WECHATPAY_API_V3_KEY=
WECHATPAY_SERIAL=
